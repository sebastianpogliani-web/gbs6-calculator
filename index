<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calculadora de Visitas – Estudio GBS6 C1091009 | iTRIALS</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Calibri:wght@300;400;700&display=swap');

  :root {
    --dark:    #3F3F3E;
    --red:     #E61D2B;
    --gray:    #999999;
    --light:   #F5F5F5;
    --white:   #FFFFFF;
    --border:  #E0E0E0;
    --ok:      #2E7D4F;
    --ok-bg:   #EDF7F2;
    --ok-bdr:  #B6DEC8;
    --warn:    #E61D2B;
    --warn-bg: #FDF0F0;
    --warn-bdr:#F5C0C3;
    --gold:    #B8892A;
    --gold-bg: #FDF8EE;
    --gold-bdr:#F0D898;
    --blue:    #1A4FA0;
    --blue-bg: #EEF3FB;
    --blue-bdr:#BACED4;
    --radius:  6px;
    --shadow:  0 2px 10px rgba(0,0,0,0.07);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Calibri', Calibri, sans-serif;
    background: #F2F2F2;
    color: var(--dark);
    min-height: 100vh;
    padding-bottom: 60px;
    font-size: 15px;
  }

  /* ── HEADER ── */
  header {
    background: var(--dark);
    color: var(--white);
    padding: 0;
  }
  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 36px;
    border-bottom: 3px solid var(--red);
  }
  .logo-area {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .logo-svg { flex-shrink: 0; }
  .logo-text-block {}
  .logo-name {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--white);
    line-height: 1;
  }
  .logo-name span { color: var(--red); }
  .logo-tagline {
    font-size: 10px;
    color: var(--gray);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 3px;
  }
  .header-badge {
    background: rgba(230,29,43,0.15);
    border: 1px solid rgba(230,29,43,0.35);
    border-radius: 3px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 5px 12px;
    color: #ff8080;
    text-transform: uppercase;
  }
  .header-body {
    padding: 24px 36px 28px;
  }
  .header-body h1 {
    font-size: clamp(20px, 4vw, 26px);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 5px;
    line-height: 1.2;
  }
  .header-body p {
    font-size: 13px;
    color: var(--gray);
    font-weight: 300;
  }
  .red-bar {
    height: 4px;
    background: linear-gradient(90deg, var(--red) 0%, transparent 100%);
  }

  /* ── MAIN ── */
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 28px 20px 0;
  }

  /* ── CARD ── */
  .card {
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 24px 28px;
    margin-bottom: 16px;
    box-shadow: var(--shadow);
  }
  .card-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .card-title .bar {
    width: 4px; height: 18px;
    background: var(--red);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .card-title .bar.blue { background: var(--blue); }

  /* ── INPUTS ── */
  .input-row { display: flex; gap: 14px; align-items: flex-end; flex-wrap: wrap; }
  .field { flex: 1; min-width: 110px; }
  .field-wide { flex: 2; min-width: 200px; }

  label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 6px;
  }
  input[type="number"], input[type="date"] {
    width: 100%;
    padding: 10px 13px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    font-family: 'Calibri', Calibri, sans-serif;
    font-size: 15px;
    color: var(--dark);
    background: #FAFAFA;
    transition: border-color 0.2s, box-shadow 0.2s;
    -moz-appearance: textfield;
    appearance: textfield;
  }
  input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; }
  input:focus {
    outline: none;
    border-color: var(--red);
    box-shadow: 0 0 0 3px rgba(230,29,43,0.10);
    background: var(--white);
  }
  input.blue:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(26,79,160,0.10);
  }
  .field-note { font-size: 11px; color: var(--gray); margin-top: 5px; }

  .or-row {
    display: flex; align-items: center; gap: 12px; margin: 16px 0;
    color: var(--gray); font-size: 11px; font-weight: 700;
    letter-spacing: 0.07em; text-transform: uppercase;
  }
  .or-row::before, .or-row::after { content:''; flex:1; height:1px; background:var(--border); }

  /* ── BANNER ── */
  .eligibility {
    border-radius: var(--radius);
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 18px;
    line-height: 1.5;
    border-left: 4px solid;
  }
  .eligibility.ok   { background: var(--ok-bg);   color: var(--ok);   border-color: var(--ok); }
  .eligibility.warn { background: var(--warn-bg);  color: var(--warn); border-color: var(--warn); }
  .eligibility.neutral { background: var(--light); color: var(--gray); border-color: var(--gray); }

  /* ── SECTION LABEL ── */
  .section-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.10em;
    text-transform: uppercase; color: var(--gray); margin: 20px 0 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .section-label::after { content:''; flex:1; height:1px; background:var(--border); }

  /* ── SUMMARY BOXES ── */
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(185px, 1fr));
    gap: 12px;
    margin-bottom: 6px;
  }
  .sum-box {
    border-radius: var(--radius);
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-left: 4px solid var(--gray);
  }
  .sum-box .sum-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--gray); margin-bottom: 6px; }
  .sum-box .sum-value { font-size: 16px; font-weight: 700; color: var(--dark); line-height: 1.2; }
  .sum-box .sum-sub { font-size: 11px; color: var(--gray); margin-top: 3px; }
  .sum-box.red-l   { background: var(--warn-bg); border-left-color: var(--red); }
  .sum-box.red-l .sum-value { color: var(--red); }
  .sum-box.green-l { background: var(--ok-bg);   border-left-color: var(--ok); }
  .sum-box.green-l .sum-value { color: var(--ok); }
  .sum-box.gold-l  { background: var(--gold-bg); border-left-color: var(--gold); }
  .sum-box.gold-l .sum-value { color: var(--gold); }
  .sum-box.blue-l  { background: var(--blue-bg); border-left-color: var(--blue); }
  .sum-box.blue-l .sum-value { color: var(--blue); }

  /* ── SCENARIOS ── */
  .scenario-block {
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 18px 20px;
    margin-bottom: 12px;
    background: var(--white);
  }
  .scenario-block.a { border-top: 3px solid var(--ok); }
  .scenario-block.b { border-top: 3px solid var(--blue); }
  .scenario-header { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .scenario-badge {
    width: 30px; height: 30px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; flex-shrink: 0;
  }
  .badge-a { background: var(--ok);   color: var(--white); }
  .badge-b { background: var(--blue); color: var(--white); }
  .scenario-title { font-weight: 700; font-size: 14px; color: var(--dark); }
  .scenario-subtitle { font-size: 12px; color: var(--gray); }

  .scenario-rows { display: grid; gap: 6px; }
  .s-row {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 13px; padding: 8px 12px;
    background: var(--light); border-radius: 4px; gap: 12px;
  }
  .s-row .s-key { color: var(--gray); font-size: 12px; flex-shrink: 0; }
  .s-row .s-val { font-weight: 700; color: var(--dark); text-align: right; }
  .s-row .s-val.ok   { color: var(--ok); }
  .s-row .s-val.warn { color: var(--red); }
  .s-row .s-val.blue { color: var(--blue); }

  .feasibility {
    display: inline-flex; align-items: center; gap: 6px;
    border-radius: 3px; padding: 5px 12px;
    font-size: 12px; font-weight: 700; margin-top: 12px;
  }
  .feas-ok   { background: var(--ok-bg);   color: var(--ok);   border: 1px solid var(--ok-bdr); }
  .feas-warn { background: var(--gold-bg);  color: var(--gold); border: 1px solid var(--gold-bdr); }
  .feas-no   { background: var(--warn-bg);  color: var(--red);  border: 1px solid var(--warn-bdr); }

  /* ── NARRATIVE ── */
  .narrative {
    background: #FAFAFA;
    border-left: 4px solid var(--red);
    padding: 14px 18px;
    font-size: 13px; line-height: 1.75; color: #555;
    margin-top: 4px; border-radius: 0 var(--radius) var(--radius) 0;
  }
  .narrative strong { color: var(--dark); }

  /* ── VISITS ── */
  .visits-grid { display: grid; gap: 10px; }
  .visit-card {
    border-radius: var(--radius); border: 1px solid var(--border);
    padding: 14px 18px; background: var(--white);
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: center; gap: 14px;
    box-shadow: var(--shadow);
  }
  .visit-card.hi { border-left: 4px solid var(--red); }
  .visit-number {
    width: 36px; height: 36px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 700; flex-shrink: 0;
  }
  .v0 { background: #E8EEFA; color: #2B5DD1; }
  .v1 { background: var(--warn-bg); color: var(--red); border: 2px solid var(--red); }
  .v2 { background: #F0EAFA; color: #7B4FC5; }
  .v3 { background: #FFF3E0; color: #E67E22; }
  .v4 { background: #FCE8F5; color: #C050A0; }
  .v5 { background: #E0F7FA; color: #0288D1; }
  .visit-name { font-weight: 700; font-size: 13.5px; margin-bottom: 2px; color: var(--dark); }
  .visit-desc { font-size: 11.5px; color: var(--gray); }
  .visit-window { font-size: 11px; color: var(--red); font-weight: 700; margin-top: 3px; }
  .visit-dates { text-align: right; flex-shrink: 0; }
  .visit-date-main { font-weight: 700; font-size: 13px; color: var(--dark); }
  .visit-date-range { font-size: 11px; color: var(--gray); margin-top: 1px; }

  /* ── EMPTY ── */
  .empty { text-align: center; padding: 36px 20px; color: var(--gray); font-size: 14px; }
  .empty .ico { font-size: 32px; margin-bottom: 10px; }

  /* ── FOOTER ── */
  footer {
    max-width: 860px; margin: 40px auto 0;
    padding: 20px 20px 0;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    gap: 20px; flex-wrap: wrap;
  }
  .footer-logo { display: flex; align-items: center; gap: 10px; }
  .footer-text { font-size: 11px; color: var(--gray); line-height: 1.6; }
  .footer-text strong { color: var(--dark); }

  @keyframes fadeIn { from { opacity:0; transform:translateY(5px); } to { opacity:1; transform:translateY(0); } }
  .anim { animation: fadeIn 0.3s ease both; }

  @media (max-width:560px) {
    .header-top { flex-direction: column; align-items: flex-start; gap: 12px; padding: 16px 20px; }
    .header-body { padding: 18px 20px 22px; }
    .card { padding: 18px; }
    .input-row { flex-direction: column; }
    .field, .field-wide { min-width: 100%; }
    .visit-card { grid-template-columns: auto 1fr; }
    .visit-dates { grid-column: 2; text-align: left; }
    .summary-grid { grid-template-columns: 1fr 1fr; }
    footer { flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>

<header>
  <div class="header-top">
    <div class="logo-area">
      <!-- iTRIALS SVG Logo (isotipo recreado según brandbook) -->
      <img src="data:image/png;base64," alt="iTRIALS" style="height:52px;width:auto;">
    </div>
    <div class="header-badge">Protocolo C1091009 · Enmienda 2</div>
  </div>
  <div class="header-body">
    <h1>Calculadora de Visitas del Estudio GBS6</h1>
    <p>Vacuna hexavalente contra estreptococo del grupo B en embarazadas · Incluye interacción con vacuna RSV</p>
  </div>
  <div class="red-bar"></div>
</header>

<main>

  <!-- BLOQUE 1: EG -->
  <div class="card">
    <div class="card-title"><span class="bar"></span>Edad gestacional actual</div>
    <div class="input-row">
      <div class="field">
        <label>Semanas</label>
        <input type="number" id="weeks" min="10" max="40" placeholder="ej. 32" oninput="onEgChange()">
      </div>
      <div class="field">
        <label>Días (0–6)</label>
        <input type="number" id="days" min="0" max="6" placeholder="ej. 6" oninput="onEgChange()">
      </div>
      <div class="field-wide">
        <label>Fecha de hoy</label>
        <input type="date" id="today" oninput="onEgChange()">
      </div>
    </div>
    <div class="or-row">ó ingresá la fecha estimada de parto</div>
    <div class="input-row">
      <div class="field-wide">
        <label>Fecha probable de parto (FPP)</label>
        <input type="date" id="fpp" oninput="onFppChange()">
        <div class="field-note">Al ingresar la FPP se calcula la EG automáticamente</div>
      </div>
    </div>
    <div id="eg-banner" class="eligibility neutral" style="display:none">
      <span>⏳</span>
      <span id="eg-banner-text">Completá los datos para ver la elegibilidad.</span>
    </div>
  </div>

  <!-- BLOQUE 2: RSV -->
  <div class="card">
    <div class="card-title"><span class="bar blue"></span>Vacuna RSV <span style="font-weight:300;font-size:13px;color:var(--gray);text-transform:none;letter-spacing:0;margin-left:4px;">(opcional)</span></div>
    <p style="font-size:13px;color:var(--gray);margin-bottom:16px;line-height:1.6;">
      El protocolo requiere <strong style="color:var(--dark)">≥15 días</strong> de separación entre la vacuna RSV y la vacuna del estudio (GBS6), en cualquier orden.
    </p>
    <div class="input-row">
      <div class="field-wide">
        <label>Fecha de vacunación RSV (recibida o planificada)</label>
        <input type="date" id="rsv-date" class="blue" oninput="calculate()">
        <div class="field-note">Dejá vacío para ver solo los escenarios sin RSV</div>
      </div>
    </div>
  </div>

  <!-- RESULTADOS -->
  <div id="results" style="display:none">

    <div class="section-label">Ventanas críticas</div>
    <div class="summary-grid anim" id="summary-grid"></div>

    <div class="section-label" style="margin-top:18px">Escenarios con vacuna RSV</div>
    <div id="rsv-scenarios"></div>

    <div class="narrative anim" id="narrative" style="margin-top:4px"></div>

    <div class="section-label" style="margin-top:20px">Cronograma de visitas · Madre participante</div>
    <div class="visits-grid" id="visits-grid"></div>

  </div>

  <div id="empty-state" class="empty" style="display:none">
    <div class="ico">🚫</div>
    <strong>Participante no elegible</strong><br>
    La EG actual está fuera de la ventana de vacunación del protocolo (24+0 a 36+0 semanas).
  </div>

</main>

<footer>
  <div class="footer-logo">
    <img src="data:image/png;base64," alt="iTRIALS" style="height:36px;width:auto;">
  </div>
  <div class="footer-text">
    <strong>Protocolo C1091009 · Pfizer Inc.</strong> · Enmienda 2 · 27 mayo 2025<br>
    Herramienta de uso interno para centros investigadores. Verificar siempre con el protocolo vigente.
  </div>
</footer>

<script>
const MONTHS = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];

function addDays(dateStr, n) {
  const d = new Date(dateStr + 'T12:00:00');
  d.setDate(d.getDate() + n);
  return d.toISOString().slice(0,10);
}
function diffDays(a, b) {
  return Math.round((new Date(b+'T12:00:00') - new Date(a+'T12:00:00')) / 86400000);
}
function fmt(dateStr) {
  if (!dateStr) return '—';
  const [y,m,d] = dateStr.split('-');
  return `${parseInt(d)} ${MONTHS[parseInt(m)-1]} ${y}`;
}
function daysFromEg(w,d) { return w*7 + parseInt(d||0); }
function egFromDays(td)  { return { w: Math.floor(td/7), d: td%7 }; }

function onFppChange() {
  const t = document.getElementById('today').value;
  const f = document.getElementById('fpp').value;
  if (!t || !f) { calculate(); return; }
  const egD = 280 - diffDays(t, f);
  if (egD > 0) {
    const {w,d} = egFromDays(egD);
    document.getElementById('weeks').value = w;
    document.getElementById('days').value  = d;
  }
  calculate();
}

function onEgChange() {
  const t = document.getElementById('today').value;
  const w = parseInt(document.getElementById('weeks').value||0);
  const d = parseInt(document.getElementById('days').value||0);
  if (t && w) {
    document.getElementById('fpp').value = addDays(t, 280 - daysFromEg(w,d));
  }
  calculate();
}

function calculate() {
  const weeksRaw = document.getElementById('weeks').value;
  const daysRaw  = document.getElementById('days').value;
  const today    = document.getElementById('today').value;
  const rsvDate  = document.getElementById('rsv-date').value;

  const banner  = document.getElementById('eg-banner');
  const results = document.getElementById('results');
  const emptyEl = document.getElementById('empty-state');

  if (!weeksRaw || !today) {
    banner.style.display = 'none';
    results.style.display = 'none';
    emptyEl.style.display = 'none';
    return;
  }

  const w  = parseInt(weeksRaw);
  const d  = parseInt(daysRaw||0);
  const eg = daysFromEg(w, d);
  const MIN_EG = daysFromEg(24,0);
  const MAX_EG = daysFromEg(36,0);

  banner.style.display = 'flex';

  if (eg < MIN_EG || eg > MAX_EG) {
    banner.className = 'eligibility warn';
    const msg = eg < MIN_EG
      ? `Con ${w}+${d} sem, la EG es <strong>menor de 24+0 semanas</strong>. Aún no es elegible para vacunación.`
      : `Con ${w}+${d} sem, la EG <strong>supera las 36+0 semanas</strong>. No elegible según el protocolo.`;
    document.getElementById('eg-banner-text').innerHTML = `⛔ ${msg}`;
    results.style.display = 'none';
    emptyEl.style.display = 'block';
    return;
  }

  const group = getGroup(eg);
  banner.className = 'eligibility ok';
  document.getElementById('eg-banner-text').innerHTML =
    `✅ Elegible · EG actual: <strong>${w}+${d} sem</strong> · ${group.label}`;

  emptyEl.style.display = 'none';
  results.style.display = 'block';

  const daysTo36 = MAX_EG - eg;
  const lastV1   = addDays(today, daysTo36);
  const fppDate  = addDays(today, 280 - eg);

  renderSummary(w, d, today, daysTo36, lastV1, fppDate, group, eg);
  renderRSV(today, rsvDate, lastV1);
  renderNarrative(w, d, today, rsvDate, lastV1, daysTo36);
  renderVisits(today, lastV1, fppDate);
}

function getGroup(eg) {
  if (eg >= daysFromEg(32,0)) return { label:'Grupo 1: 32+0 – 36+0 sem' };
  if (eg >= daysFromEg(28,0)) return { label:'Grupo 2: 28+0 – <32+0 sem' };
  return { label:'Grupo 3: 24+0 – <28+0 sem' };
}

function renderSummary(w, d, today, daysTo36, lastV1, fppDate, group, eg) {
  const col = daysTo36 <= 7 ? 'red-l' : daysTo36 <= 14 ? 'gold-l' : 'green-l';
  const urg = daysTo36 <= 7 ? '⚠️ Muy corta' : daysTo36 <= 14 ? '⚠️ Atención' : '✅ Holgada';
  document.getElementById('summary-grid').innerHTML = `
    <div class="sum-box ${col}">
      <div class="sum-label">Último día para V1</div>
      <div class="sum-value">${fmt(lastV1)}</div>
      <div class="sum-sub">${daysTo36} días desde hoy · ${urg}</div>
    </div>
    <div class="sum-box">
      <div class="sum-label">Ventana selección (V0)</div>
      <div class="sum-value" style="font-size:13px">Hoy al ${fmt(lastV1)}</div>
      <div class="sum-sub">Puede ser el mismo día que V1</div>
    </div>
    <div class="sum-box blue-l">
      <div class="sum-label">FPP estimada (40 sem)</div>
      <div class="sum-value">${fmt(fppDate)}</div>
      <div class="sum-sub">${280-eg} días desde hoy</div>
    </div>
    <div class="sum-box">
      <div class="sum-label">Grupo de inscripción</div>
      <div class="sum-value" style="font-size:13px">${group.label}</div>
      <div class="sum-sub">Según EG al momento de V1</div>
    </div>
  `;
}

function renderRSV(today, rsvDate, lastV1) {
  const RSV_GAP = 15;
  const rsvMinA_today = addDays(today, RSV_GAP);
  const rsvMinA_last  = addDays(lastV1, RSV_GAP);

  let scenB = '';
  if (rsvDate) {
    const firstV1    = addDays(rsvDate, RSV_GAP);
    const v1WinStart = firstV1 > today ? firstV1 : today;
    const windowDays = diffDays(v1WinStart, lastV1);
    const rsvPast    = rsvDate <= today;
    const gapToday   = Math.abs(diffDays(rsvDate, today));
    const rsvStatus  = rsvPast
      ? `Recibida hace ${gapToday} día${gapToday!==1?'s':''}`
      : `Planificada en ${gapToday} día${gapToday!==1?'s':''}`;

    let fc = 'feas-ok', fl = '✅ Factible';
    if (windowDays < 0)       { fc = 'feas-no';   fl = '❌ Sin ventana disponible'; }
    else if (windowDays <= 7) { fc = 'feas-warn';  fl = `⚠️ Ventana muy corta (${windowDays} días)`; }
    else fl = `✅ Factible · ${windowDays} días de ventana`;

    scenB = `
      <div class="scenario-block b anim">
        <div class="scenario-header">
          <div class="scenario-badge badge-b">B</div>
          <div>
            <div class="scenario-title">RSV primero → GBS6 después</div>
            <div class="scenario-subtitle">${rsvStatus}</div>
          </div>
        </div>
        <div class="scenario-rows">
          <div class="s-row"><span class="s-key">💉 Fecha vacuna RSV</span><span class="s-val blue">${fmt(rsvDate)}</span></div>
          <div class="s-row"><span class="s-key">⏱ Primer V1 posible (RSV + 15 d)</span><span class="s-val ${windowDays<0?'warn':'ok'}">${fmt(firstV1)}</span></div>
          <div class="s-row"><span class="s-key">🔚 Último V1 posible (36+0)</span><span class="s-val">${fmt(lastV1)}</span></div>
          <div class="s-row"><span class="s-key">📆 Ventana de V1 resultante</span>
            <span class="s-val ${windowDays<0?'warn':'ok'}">
              ${windowDays<0 ? 'Sin ventana' : `${fmt(v1WinStart)} al ${fmt(lastV1)}`}
            </span>
          </div>
        </div>
        <div class="${fc} feasibility">${fl}</div>
      </div>`;
  } else {
    scenB = `
      <div class="scenario-block b" style="opacity:0.55">
        <div class="scenario-header">
          <div class="scenario-badge badge-b">B</div>
          <div>
            <div class="scenario-title">RSV primero → GBS6 después</div>
            <div class="scenario-subtitle">Ingresá una fecha RSV arriba para calcular este escenario</div>
          </div>
        </div>
      </div>`;
  }

  document.getElementById('rsv-scenarios').innerHTML = `
    <div class="scenario-block a anim">
      <div class="scenario-header">
        <div class="scenario-badge badge-a">A</div>
        <div>
          <div class="scenario-title">GBS6 primero → RSV después</div>
          <div class="scenario-subtitle">Vacuna del estudio primero · RSV a partir de V1 + 15 días</div>
        </div>
      </div>
      <div class="scenario-rows">
        <div class="s-row"><span class="s-key">💉 Ventana de V1 (GBS6)</span><span class="s-val ok">Hoy (${fmt(today)}) al ${fmt(lastV1)}</span></div>
        <div class="s-row"><span class="s-key">🔵 RSV mínima si V1 = hoy</span><span class="s-val blue">${fmt(rsvMinA_today)} en adelante</span></div>
        <div class="s-row"><span class="s-key">🔵 RSV mínima si V1 = último día</span><span class="s-val blue">${fmt(rsvMinA_last)} en adelante</span></div>
      </div>
      <div class="feas-ok feasibility">✅ Siempre factible dentro de la ventana de V1</div>
    </div>
    ${scenB}
  `;
}

function renderNarrative(w, d, today, rsvDate, lastV1, daysTo36) {
  const RSV_GAP = 15;
  let txt = `Hoy la participante está en <strong>${w}+${d} semanas</strong> de gestación. `;
  txt += `La última fecha posible para la vacunación del estudio (V1) es el <strong>${fmt(lastV1)}</strong> (${daysTo36} días). `;
  if (rsvDate) {
    const firstV1    = addDays(rsvDate, RSV_GAP);
    const v1WinStart = firstV1 > today ? firstV1 : today;
    const windowDays = diffDays(v1WinStart, lastV1);
    if (windowDays < 0) {
      txt += `Con RSV el ${fmt(rsvDate)}, el primer V1 posible sería el <strong>${fmt(firstV1)}</strong>, que <strong>supera el límite de 36+0 semanas</strong>. ❌ No es posible inscribir en el Escenario B.`;
    } else {
      txt += `Con RSV el <strong>${fmt(rsvDate)}</strong>, el primer V1 posible es el <strong>${fmt(firstV1)}</strong> y el último el <strong>${fmt(lastV1)}</strong> — quedan <strong>${windowDays} días</strong> de ventana. `;
    }
  } else {
    txt += `Si hoy recibe RSV, el primer V1 posible sería el <strong>${fmt(addDays(today, RSV_GAP))}</strong>. `;
  }
  txt += `La selección (V0) puede realizarse desde hoy hasta el <strong>${fmt(lastV1)}</strong>.`;
  document.getElementById('narrative').innerHTML = txt;
}

function renderVisits(today, lastV1, fppDate) {
  const v2s = addDays(today, 28), v2e = addDays(today, 42);
  const v4s = addDays(fppDate, 28), v4e = addDays(fppDate, 42);
  const v5s = addDays(v4s, 180), v5e = addDays(v4e, 210);

  const visits = [
    { id:'v0', num:'0', name:'Visita 0 – Selección',
      desc:'Consentimiento informado, laboratorios, ecografía, demografía',
      window:`Hasta 28 días antes de V1 · puede ser el mismo día`,
      main:`Hoy, ${fmt(today)}`, sub:`al ${fmt(lastV1)}` },
    { id:'v1', num:'1', name:'Visita 1 – Vacunación (Día 1)',
      desc:'Administración GBS6 o placebo · EG debe ser 24+0 a 36+0 sem',
      window:`Desde hoy hasta ${fmt(lastV1)}`,
      main:fmt(today), sub:`al ${fmt(lastV1)}`, hi:true },
    { id:'v2', num:'2', name:'Visita 2 – Seguimiento 1 mes post-vacunación',
      desc:'Extracción de sangre (inmunogenicidad), seguridad materna',
      window:'28 a 42 días después de V1',
      main:fmt(v2s), sub:`al ${fmt(v2e)}` },
    { id:'v3', num:'3', name:'Visita 3 – Parto',
      desc:'Unidad de maternidad · Sangre materna y cordón umbilical',
      window:'Desde ingreso al trabajo de parto hasta el alta',
      main:fmt(fppDate), sub:'FPP estimada (40 sem)' },
    { id:'v4', num:'4', name:'Visita 4 – Seguimiento 1 mes post-parto',
      desc:'Visita clínica o llamada telefónica · Seguridad materna y del bebé',
      window:'28 a 42 días después del parto',
      main:fmt(v4s), sub:`al ${fmt(v4e)}` },
    { id:'v5', num:'5', name:'Visita 5 – Llamada 6 meses post-parto',
      desc:'Llamada telefónica · Cierre del seguimiento materno',
      window:'180 a 210 días después de Visita 4',
      main:fmt(v5s), sub:`al ${fmt(v5e)}` },
  ];

  document.getElementById('visits-grid').innerHTML = visits.map(v => `
    <div class="visit-card ${v.hi?'hi':''} anim">
      <div class="visit-number ${v.id}">${v.num}</div>
      <div>
        <div class="visit-name">${v.name}</div>
        <div class="visit-desc">${v.desc}</div>
        <div class="visit-window">${v.window}</div>
      </div>
      <div class="visit-dates">
        <div class="visit-date-main">${v.main}</div>
        <div class="visit-date-range">${v.sub}</div>
      </div>
    </div>
  `).join('');
}

// Init
document.getElementById('today').value = new Date().toISOString().slice(0,10);
</script>
